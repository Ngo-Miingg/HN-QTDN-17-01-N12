<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_phieu_luong_tree" model="ir.ui.view">
        <field name="name">hr_phieu_luong.tree</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <tree string="Phieu luong">
                <field name="thang"/>
                <field name="nam"/>
                <field name="nhan_vien_id"/>
                <field name="ma_dinh_danh"/>
                <field name="so_ngay_cong"/>
                <field name="luong_co_ban"/>
                <field name="tong_phu_cap"/>
                <field name="tong_khen_thuong"/>
                <field name="tong_ky_luat"/>
                <field name="thuc_linh"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_phieu_luong_form" model="ir.ui.view">
        <field name="name">hr_phieu_luong.form</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <form string="Phieu luong">
                <sheet>
                    <group>
                        <group>
                            <field name="nhan_vien_id"/>
                            <field name="ma_dinh_danh" readonly="1"/>
                            <field name="thang"/>
                            <field name="nam"/>
                        </group>
                        <group>
                            <field name="so_ngay_di_lam" readonly="1"/>
                            <field name="so_ngay_nua_ngay" readonly="1"/>
                            <field name="so_ngay_cong" readonly="1"/>
                        </group>
                    </group>
                    <group string="Tinh luong">
                        <group>
                            <field name="luong_co_ban" readonly="1"/>
                            <field name="tong_phu_cap" readonly="1"/>
                        </group>
                        <group>
                            <field name="tong_khen_thuong" readonly="1"/>
                            <field name="tong_ky_luat" readonly="1"/>
                            <field name="thuc_linh" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ghi chu">
                            <field name="ghi_chu"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_phieu_luong_search" model="ir.ui.view">
        <field name="name">hr_phieu_luong.search</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <search string="Tim phieu luong">
                <field name="nhan_vien_id"/>
                <field name="thang"/>
                <field name="nam"/>
                <group expand="0" string="Nhom theo">
                    <filter string="Nhan vien" name="group_nhan_vien" context="{'group_by': 'nhan_vien_id'}"/>
                    <filter string="Nam" name="group_nam" context="{'group_by': 'nam'}"/>
                    <filter string="Thang" name="group_thang" context="{'group_by': 'thang'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_phieu_luong" model="ir.actions.act_window">
        <field name="name">Phieu luong</field>
        <field name="res_model">hr_phieu_luong</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_hr_phieu_luong_search"/>
    </record>
</odoo>
